# mefaltauna — environment variables
# Copy this file to .env.local and fill in real values.

# ─── Supabase ─────────────────────────────────────────────
# Create a project at https://app.supabase.com, then go to:
#   Project Settings → API
# and copy the values below.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# ─── Site URL ─────────────────────────────────────────────
# Used by magic links to redirect back to the right host after auth.
# Locally: http://localhost:3000 (or 3001).
# Production: https://mefaltauna.vercel.app (or your custom domain).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
